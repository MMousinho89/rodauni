RewriteEngine On

# ============================================
# 1) IGNORAR LOCALHOST (DEV)
# ============================================
RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1)$ [NC]
RewriteRule ^ - [L]

# ============================================
# 2) SE JÁ ESTIVER EM /sistema/public, NÃO REDIRECIONA
# ============================================
RewriteCond %{REQUEST_URI} ^/sistema/public/ [NC]
RewriteRule ^ - [L]

# ============================================
# 3) RAIZ DO PROJETO -> /sistema/public/
# ============================================
RewriteRule ^$ sistema/public/ [L]

# ============================================
# 4) QUALQUER ACESSO DO PROJETO -> /sistema/public/
# ============================================
RewriteCond %{REQUEST_URI} !^/sistema/public/ [NC]
RewriteRule ^(.*)$ sistema/public/$1 [L]