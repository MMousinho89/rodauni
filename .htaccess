RewriteEngine On

# ============================================
# 1) IGNORAR LOCALHOST (DEV)
# ============================================
RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1)$ [NC]
RewriteRule ^ - [L]

# ============================================
# 2) FORÇAR HTTPS EM PRODUÇÃO
# ============================================
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================
# 3) REDIRECIONAR PARA /uniaopirestransportes
# ============================================
RewriteCond %{REQUEST_URI} !^/uniaopirestransportes/
RewriteRule ^(.*)$ /uniaopirestransportes/$1 [L]